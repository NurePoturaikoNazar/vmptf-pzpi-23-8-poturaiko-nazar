<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="80dp"
        android:paddingBottom="24dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Practical Work 3"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:textColor="?attr/colorPrimary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select a Task to Begin"
            android:textSize="16sp"
            android:layout_marginBottom="48dp"
            android:textColor="?attr/colorOutline"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTask1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task 1: Calculator"
            android:layout_marginBottom="16dp"
            android:padding="16dp"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_add"
            style="@style/Widget.Material3.Button"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTask2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task 2: Calendar"
            android:layout_marginBottom="16dp"
            android:padding="16dp"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTask3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task 3: Word Game"
            android:layout_marginBottom="16dp"
            android:padding="16dp"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_edit"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTask4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task 4: Roman Converter"
            android:padding="16dp"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            style="@style/Widget.Material3.Button.TonalButton"/>

    </LinearLayout>
</ScrollView>